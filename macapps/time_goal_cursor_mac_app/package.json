{
  "name": "time_goal_cursor_mac_app",
  "version": "1.0.0",
  "description": "A system-wide cursor tracker with time and focus goals.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "build": {
    "appId": "com.ikbhal.cursor-time-tracker",
    "productName": "CursorTimeTracker",
    "mac": {
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "files": [
      "**/*",
      "!dist/*"
    ]
  },
  "keywords": [],
  "author": "ikbhal",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron-store": "6.0.1"
  },
  "devDependencies": {
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1"
  }
}
